# Archivo .env para configuración local

# Node Environment
NODE_ENV=development

# Database
DATABASE_URL=mysql://obrafirmada_user:obrafirmada_dev_password@localhost:3306/obrafirmada_dev

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Bcrypt
BCRYPT_ROUNDS=10

# Server
PORT=3001

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api
