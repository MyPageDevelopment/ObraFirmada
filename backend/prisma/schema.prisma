// Prisma Schema para ObraFirmada
// Esquema moderno para enrolamiento biométrico y firma de documentos laborales

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

/// Modelo User: Representa trabajadores enrolados en el sistema
/// Seguridad: Nunca se almacenan imagenes biometrica originales
model User {
  /// Identificador unico (cuid)
  id String @id @default(cuid())

  /// RUT chileno validado y normalizado (ej: "12345678-9")
  /// Unico en el sistema
  rut String @unique @db.VarChar(12)

  /// Marca de tiempo: Creacion del registro
  createdAt DateTime @default(now())

  /// Marca de tiempo: Ultima actualizacion
  updatedAt DateTime @updatedAt

  /// Relacion: Un usuario puede tener multiples logs de identidad
  identityLogs IdentityLog[]

  @@index([rut])
  @@index([createdAt])
}

/// Modelo IdentityLog: Registro inmutable de identidad
/// Contiene vector biometrico cifrado y firma manuscrita (Base64)
model IdentityLog {
  id String @id @default(cuid())

  /// Relacion con el usuario enrolado
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// RUT (denormalizado para auditoria rapida)
  rut String @db.VarChar(12)

  /// Vector biometrico cifrado con AES-256-GCM
  /// CRITICO: nunca almacenar imagen original
  encryptedBiometricVector String @db.LongText

  /// Firma manuscrita digital en Base64 (canvas)
  signatureBase64 String @db.LongText

  /// Tipo de biometria: FACE, PALM
  biometricType String @db.VarChar(20)

  /// Marca temporal de captura
  capturedAt DateTime @default(now())

  /// Marca temporal de creacion del log
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rut])
  @@index([capturedAt])
}
